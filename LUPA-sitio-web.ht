ease}\n  .lupa-card:hover{transform:translateY(-6px)}\n  .lupa-card:hover .lupa-img{transform:scale(1.04)}\n  .lupa-img{transition:transform .9s cubic-bezier(.2,.7,.2,1)}\n  .lupa-btn{transition:background .3s ease,color .3s ease,border-color .3s ease,transform .2s ease}\n  .lupa-btn:active{transform:translateY(1px)}\n  @media(min-width:860px){.lupa-nav-links{display:flex !important}}\n  @media(max-width:760px){\n    .lupa-hero-split{grid-template-columns:1fr !important}\n    .lupa-2col{grid-template-columns:1fr !important}\n  }\n<\u002Fstyle>\n<\u002Fhelmet>\n\n\n<div style=\"background:#F4ECDF;color:#2A2420;overflow-x:hidden\">\n\n  <!-- NAV -->\n  <nav style=\"position:sticky;top:0;z-index:50;display:flex;align-items:center;justify-content:space-between;padding:18px clamp(20px,5vw,56px);background:rgba(244,236,223,.86);backdrop-filter:blur(12px);border-bottom:1px solid rgba(166,128,63,.22)\">\n    <a href=\"#top\" style=\"text-decoration:none;display:flex;align-items:center;gap:12px\">\n      <span style=\"display:grid;place-items:center;width:38px;height:38px;border:1.5px solid #A6803F;border-radius:8px;font-family:'Cormorant Garamond',serif;font-weight:600;font-size:18px;color:#A6803F;letter-spacing:1px\">LU<\u002Fspan>\n      <span style=\"display:flex;flex-direction:column;line-height:1\">\n        <span style=\"font-family:'Cormorant Garamond',serif;font-size:25px;font-weight:600;letter-spacing:.14em;color:#2A2420\">LUPA<\u002Fspan>\n        <span style=\"font-size:8.5px;letter-spacing:.34em;text-transform:uppercase;color:#A6803F;margin-top:3px\">ambos de diseño exclusivo<\u002Fspan>\n      <\u002Fspan>\n    <\u002Fa>\n    <div style=\"display:none;gap:38px;align-items:center\" class=\"lupa-nav-links\">\n      <a href=\"#coleccion\" class=\"lupa-link\" style=\"text-decoration:none;color:#3a342e;font-size:13px;letter-spacing:.14em;text-transform:uppercase\">Colección<\u002Fa>\n      <a href=\"#empresas\" class=\"lupa-link\" style=\"text-decoration:none;color:#3a342e;font-size:13px;letter-spacing:.14em;text-transform:uppercase\">Empresas<\u002Fa>\n      <a href=\"#filosofia\" class=\"lupa-link\" style=\"text-decoration:none;color:#3a342e;font-size:13px;letter-spacing:.14em;text-transform:uppercase\">Filosofía<\u002Fa>\n      <a href=\"#contacto\" class=\"lupa-link\" style=\"text-decoration:none;color:#3a342e;font-size:13px;letter-spacing:.14em;text-transform:uppercase\">Contacto<\u002Fa>\n    <\u002Fdiv>\n    <a href=\"{{ waHref }}\" target=\"_blank\" rel=\"noopener\" class=\"lupa-btn\" style=\"text-decoration:none;display:inline-flex;align-items:center;gap:9px;padding:11px 22px;border:1px solid #A6803F;border-radius:100px;color:#A6803F;font-size:12px;letter-spacing:.16em;text-transform:uppercase\" style-hover=\"background:#A6803F;color:#F4ECDF\">WhatsApp<\u002Fa>\n  <\u002Fnav>\n\n  <span id=\"top\"><\u002Fspan>\n\n  <!-- HERO A — editorial split -->\n  <sc-if value=\"{{ heroA }}\" hint-placeholder-val=\"{{ true }}\">\n  <section class=\"lupa-hero-split\" style=\"display:grid;grid-template-columns:1.05fr 1fr;min-height:90vh;align-items:stretch\">\n    <div style=\"display:flex;flex-direction:column;justify-content:center;padding:clamp(40px,7vw,96px)\">\n      <span style=\"font-size:12px;letter-spacing:.34em;text-transform:uppercase;color:#A6803F;font-weight:500\">Ambos de diseño exclusivo<\u002Fspan>\n      <h1 style=\"font-family:'Cormorant Garamond',serif;font-weight:400;font-size:clamp(46px,6.4vw,86px);line-height:1.0;letter-spacing:-.015em;margin:26px 0 0;color:#2A2420\">Pensados<br>para que <em style=\"font-style:italic;color:#A6803F\">ames<\u002Fem><br>ir a trabajar.<\u002Fh1>\n      <p style=\"max-width:430px;margin:30px 0 0;font-size:17px;line-height:1.75;color:#5C5249;font-weight:300\">Dejamos atrás el ambo clásico para vestir tu profesión con elegancia. Cortes originales, caída impecable y un detalle que nunca pasa desapercibido.<\u002Fp>\n      <div style=\"display:flex;gap:16px;flex-wrap:wrap;margin-top:40px\">\n        <a href=\"#coleccion\" class=\"lupa-btn\" style=\"text-decoration:none;padding:15px 30px;background:#2A2420;color:#F4ECDF;border-radius:100px;font-size:12.5px;letter-spacing:.16em;text-transform:uppercase\" style-hover=\"background:#A6803F\">Ver la colección<\u002Fa>\n        <a href=\"{{ tiendaHref }}\" target=\"_blank\" rel=\"noopener\" class=\"lupa-btn\" style=\"text-decoration:none;padding:15px 30px;border:1px solid #2A2420;color:#2A2420;border-radius:100px;font-size:12.5px;letter-spacing:.16em;text-transform:uppercase\" style-hover=\"background:#2A2420;color:#F4ECDF\">Comprar ahora<\u002Fa>\n      <\u002Fdiv>\n      <span style=\"margin-top:48px;font-size:12px;letter-spacing:.22em;text-transform:uppercase;color:#A6803F\">Corrientes · Argentina<\u002Fspan>\n    <\u002Fdiv>\n    <div style=\"position:relative;overflow:hidden;min-height:60vh;background:#E7D8C4\">\n      <img src=\"848c2cf6-8706-422d-9651-ffc556591ece\" alt=\"Modelo LUPA en consultorio\" class=\"lupa-img\" style=\"width:100%;height:100%;object-fit:cover;object-position:center\">\n      <div style=\"position:absolute;inset:18px;border:1px solid rgba(244,236,223,.5);pointer-events:none\"><\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fsection>\n  <\u002Fsc-if>\n\n  <!-- HERO B — full bleed -->\n  <sc-if value=\"{{ heroB }}\" hint-placeholder-val=\"{{ true }}\">\n  <section style=\"position:relative;min-height:92vh;display:flex;align-items:flex-end;overflow:hidden;background:#7a4a2a\">\n    <img src=\"bd2ddfdf-88e1-4468-b3b2-190d476ea057\" alt=\"Modelos LUPA\" class=\"lupa-img\" style=\"position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center 20%\">\n    <div style=\"position:absolute;inset:0;background:linear-gradient(180deg,rgba(40,30,20,.18) 0%,rgba(40,30,20,.12) 45%,rgba(30,22,15,.78) 100%)\"><\u002Fdiv>\n    <div style=\"position:absolute;inset:24px;border:1px solid rgba(244,236,223,.35);pointer-events:none\"><\u002Fdiv>\n    <div style=\"position:relative;padding:clamp(40px,6vw,90px);max-width:760px\">\n      <span style=\"font-size:12px;letter-spacing:.34em;text-transform:uppercase;color:#E7CFA6;font-weight:500\">Ambos de diseño exclusivo<\u002Fspan>\n      <h1 style=\"font-family:'Cormorant Garamond',serif;font-weight:400;font-size:clamp(44px,6vw,82px);line-height:1.02;letter-spacing:-.015em;margin:22px 0 0;color:#F8F1E6\">Pensados para que <em style=\"font-style:italic;color:#E7CFA6\">ames<\u002Fem> ir a trabajar.<\u002Fh1>\n      <p style=\"max-width:480px;margin:26px 0 0;font-size:17px;line-height:1.75;color:rgba(248,241,230,.86);font-weight:300\">Una paleta de tonos profundos y cortes que entallan, pensados para que cada equipo encuentre el ambo que lo identifica.<\u002Fp>\n      <div style=\"display:flex;gap:16px;flex-wrap:wrap;margin-top:38px\">\n        <a href=\"#coleccion\" class=\"lupa-btn\" style=\"text-decoration:none;padding:15px 30px;background:#E7CFA6;color:#2A2420;border-radius:100px;font-size:12.5px;letter-spacing:.16em;text-transform:uppercase\" style-hover=\"background:#F8F1E6\">Ver la colección<\u002Fa>\n        <a href=\"{{ waHref }}\" target=\"_blank\" rel=\"noopener\" class=\"lupa-btn\" style=\"text-decoration:none;padding:15px 30px;border:1px solid rgba(244,236,223,.7);color:#F8F1E6;border-radius:100px;font-size:12.5px;letter-spacing:.16em;text-transform:uppercase\" style-hover=\"background:rgba(244,236,223,.15)\">Escribinos<\u002Fa>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fsection>\n  <\u002Fsc-if>\n\n  <!-- HERO C — centered manifesto -->\n  <sc-if value=\"{{ heroC }}\" hint-placeholder-val=\"{{ true }}\">\n  <section style=\"padding:clamp(56px,7vw,96px) clamp(20px,5vw,56px) clamp(40px,5vw,72px)\">\n    <div style=\"text-align:center;max-width:880px;margin:0 auto\">\n      <span style=\"font-size:12px;letter-spacing:.34em;text-transform:uppercase;color:#A6803F;font-weight:500\">Ambos de diseño exclusivo<\u002Fspan>\n      <h1 style=\"font-family:'Cormorant Garamond',serif;font-weight:400;font-size:clamp(44px,6.5vw,88px);line-height:1.02;letter-spacing:-.015em;margin:24px 0 0;color:#2A2420\">Pensados para que <em style=\"font-style:italic;color:#A6803F\">ames<\u002Fem> ir a trabajar.<\u002Fh1>\n      <p style=\"max-width:560px;margin:26px auto 0;font-size:17px;line-height:1.75;color:#5C5249;font-weight:300\">Cambiamos el ambo clásico por una propuesta elegante. Cortes originales y únicos para que nunca pases desapercibida.<\u002Fp>\n      <div style=\"display:flex;gap:16px;flex-wrap:wrap;justify-content:center;margin-top:36px\">\n        <a href=\"#coleccion\" class=\"lupa-btn\" style=\"text-decoration:none;padding:15px 30px;background:#2A2420;color:#F4ECDF;border-radius:100px;font-size:12.5px;letter-spacing:.16em;text-transform:uppercase\" style-hover=\"background:#A6803F\">Ver la colección<\u002Fa>\n        <a href=\"{{ tiendaHref }}\" target=\"_blank\" rel=\"noopener\" class=\"lupa-btn\" style=\"text-decoration:none;padding:15px 30px;border:1px solid #2A2420;color:#2A2420;border-radius:100px;font-size:12.5px;letter-spacing:.16em;text-transform:uppercase\" style-hover=\"background:#2A2420;color:#F4ECDF\">Comprar ahora<\u002Fa>\n      <\u002Fdiv>\n    <\u002Fdiv>\n    <div style=\"display:grid;grid-template-columns:repeat(3,1fr);gap:clamp(10px,1.6vw,22px);max-width:1180px;margin:clamp(40px,5vw,68px) auto 0\">\n      <div style=\"position:relative;overflow:hidden;aspect-ratio:3/4;background:#E7D8C4;border:1px solid rgba(166,128,63,.25)\"><img src=\"a121899d-dbeb-4b19-b793-97c71a5f2568\" alt=\"Ambo bordó\" class=\"lupa-img\" style=\"width:100%;height:100%;object-fit:cover;object-position:top\"><\u002Fdiv>\n      <div style=\"position:relative;overflow:hidden;aspect-ratio:3/4;background:#E7D8C4;border:1px solid rgba(166,128,63,.25)\"><img src=\"7aa1f1b9-7ae6-471e-a4b7-24265cfce633\" alt=\"Ambo verde\" class=\"lupa-img\" style=\"width:100%;height:100%;object-fit:cover;object-position:top\"><\u002Fdiv>\n      <div style=\"position:relative;overflow:hidden;aspect-ratio:3/4;background:#E7D8C4;border:1px solid rgba(166,128,63,.25)\"><img src=\"f764760c-78f9-462f-986b-f8d31f24b185\" alt=\"Ambo nude\" class=\"lupa-img\" style=\"width:100%;height:100%;object-fit:cover;object-position:top\"><\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fsection>\n  <\u002Fsc-if>\n\n  <!-- MANIFIESTO -->\n  <section style=\"padding:clamp(80px,11vw,150px) clamp(20px,5vw,56px);background:#9A6526;color:#FBF3E2;text-align:center\">\n    <span style=\"font-size:12px;letter-spacing:.34em;text-transform:uppercase;color:#F3E7C6;font-weight:500\">Mente + Corazón<\u002Fspan>\n    <p style=\"font-family:'Cormorant Garamond',serif;font-weight:300;font-size:clamp(28px,4vw,52px);line-height:1.25;letter-spacing:-.01em;max-width:1000px;margin:34px auto 0;color:#F4ECDF\">LUPA es la conjunción de dos fuerzas, <em style=\"font-style:italic;color:#FBEFD2\">mente y corazón<\u002Fem>, en cada ambo que creamos.<\u002Fp>\n    <div style=\"width:60px;height:1px;background:#F3E7C6;margin:44px auto 0\"><\u002Fdiv>\n    <p style=\"max-width:620px;margin:32px auto 0;font-size:16.5px;line-height:1.8;color:rgba(251,243,226,.86);font-weight:300\">Diseñamos pensando con la cabeza y sintiendo con el corazón: prendas que cuidan tu jornada, realzan tu silueta y dicen quién sos antes de que hables.<\u002Fp>\n  <\u002Fsection>\n\n  <!-- PROPUESTA / 3 valores -->\n  <section style=\"padding:clamp(72px,9vw,128px) clamp(20px,5vw,56px);max-width:1180px;margin:0 auto\">\n    <div style=\"display:grid;grid-template-columns:repeat(3,1fr);gap:clamp(28px,4vw,64px)\">\n      <div>\n        <span style=\"font-family:'Cormorant Garamond',serif;font-size:34px;color:#A6803F\">01<\u002Fspan>\n        <h3 style=\"font-family:'Cormorant Garamond',serif;font-weight:500;font-size:25px;margin:12px 0 10px;color:#2A2420\">Corte elegante<\u002Fh3>\n        <p style=\"font-size:15.5px;line-height:1.75;color:#5C5249;font-weight:300\">Siluetas entalladas, peplums y escotes con cierre dorado. El ambo deja de ser uniforme y se vuelve diseño.<\u002Fp>\n      <\u002Fdiv>\n      <div>\n        <span style=\"font-family:'Cormorant Garamond',serif;font-size:34px;color:#A6803F\">02<\u002Fspan>\n        <h3 style=\"font-family:'Cormorant Garamond',serif;font-weight:500;font-size:25px;margin:12px 0 10px;color:#2A2420\">Original y único<\u002Fh3>\n        <p style=\"font-size:15.5px;line-height:1.75;color:#5C5249;font-weight:300\">Detalles que no vas a ver en otro lado: mangas con volados, plisados y una paleta de tonos profundos.<\u002Fp>\n      <\u002Fdiv>\n      <div>\n        <span style=\"font-family:'Cormorant Garamond',serif;font-size:34px;color:#A6803F\">03<\u002Fspan>\n        <h3 style=\"font-family:'Cormorant Garamond',serif;font-weight:500;font-size:25px;margin:12px 0 10px;color:#2A2420\">Que te identifique<\u002Fh3>\n        <p style=\"font-size:15.5px;line-height:1.75;color:#5C5249;font-weight:300\">Asesoramos a cada profesional y a cada empresa para encontrar el ambo que mejor las representa.<\u002Fp>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fsection>\n\n  <!-- GALERIA -->\n  <section id=\"coleccion\" style=\"padding:clamp(40px,4vw,64px) clamp(20px,5vw,56px) clamp(80px,10vw,130px);max-width:1280px;margin:0 auto\">\n    <div style=\"display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:20px;margin-bottom:clamp(34px,4vw,56px)\">\n      <div>\n        <span style=\"font-size:12px;letter-spacing:.34em;text-transform:uppercase;color:#A6803F;font-weight:500\">La colección<\u002Fspan>\n        <h2 style=\"font-family:'Cormorant Garamond',serif;font-weight:400;font-size:clamp(34px,5vw,60px);line-height:1.05;letter-spacing:-.01em;margin-top:14px;color:#2A2420\">Modelos exclusivos<\u002Fh2>\n      <\u002Fdiv>\n      <p style=\"max-width:360px;font-size:15.5px;line-height:1.7;color:#5C5249;font-weight:300\">Cada modelo, una personalidad. Elegí el tuyo y consultá colores y talles por WhatsApp.<\u002Fp>\n    <\u002Fdiv>\n\n    <div style=\"display:grid;grid-template-columns:repeat(auto-fill,minmax(min(280px,100%),1fr));gap:clamp(16px,2vw,30px)\">\n\n      <div class=\"lupa-card\" style=\"background:#FBF6EC;border:1px solid rgba(166,128,63,.2)\">\n        <div style=\"position:relative;overflow:hidden;aspect-ratio:3/4;background:#E7D8C4\"><img src=\"a121899d-dbeb-4b19-b793-97c71a5f2568\" alt=\"Bordó\" class=\"lupa-img\" style=\"width:100%;height:100%;object-fit:cover;object-position:top\"><\u002Fdiv>\n        <div style=\"padding:18px 20px 22px;display:flex;align-items:flex-start;justify-content:space-between;gap:12px\">\n          <div><h3 style=\"font-family:'Cormorant Garamond',serif;font-weight:500;font-size:23px;color:#2A2420;line-height:1.1\">Bordó<\u002Fh3><p style=\"font-size:13.5px;line-height:1.55;color:#7a6f63;margin-top:5px;font-weight:300\">Escote con cierre dorado y peplum entallado.<\u002Fp><\u002Fdiv>\n          <span style=\"flex:none;width:16px;height:16px;border-radius:50%;margin-top:6px;border:1px solid rgba(0,0,0,.12);background:#6B2230\"><\u002Fspan>\n        <\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"lupa-card\" style=\"background:#FBF6EC;border:1px solid rgba(166,128,63,.2)\">\n        <div style=\"position:relative;overflow:hidden;aspect-ratio:3/4;background:#E7D8C4\"><img src=\"f764760c-78f9-462f-986b-f8d31f24b185\" alt=\"Nude\" class=\"lupa-img\" style=\"width:100%;height:100%;object-fit:cover;object-position:top\"><\u002Fdiv>\n        <div style=\"padding:18px 20px 22px;display:flex;align-items:flex-start;justify-content:space-between;gap:12px\">\n          <div><h3 style=\"font-family:'Cormorant Garamond',serif;font-weight:500;font-size:23px;color:#2A2420;line-height:1.1\">Nude<\u002Fh3><p style=\"font-size:13.5px;line-height:1.55;color:#7a6f63;margin-top:5px;font-weight:300\">Mangas plisadas y caída fluida.<\u002Fp><\u002Fdiv>\n          <span style=\"flex:none;width:16px;height:16px;border-radius:50%;margin-top:6px;border:1px solid rgba(0,0,0,.12);background:#D9A98E\"><\u002Fspan>\n        <\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"lupa-card\" style=\"background:#FBF6EC;border:1px solid rgba(166,128,63,.2)\">\n        <div style=\"position:relative;overflow:hidden;aspect-ratio:3/4;background:#E7D8C4\"><img src=\"393b981c-9acd-40b7-a38a-1a8e02c0f61e\" alt=\"Estilo Moderno\" class=\"lupa-img\" style=\"width:100%;height:100%;object-fit:cover;object-position:top\"><\u002Fdiv>\n        <div style=\"padding:18px 20px 22px;display:flex;align-items:flex-start;justify-content:space-between;gap:12px\">\n          <div><h3 style=\"font-family:'Cormorant Garamond',serif;font-weight:500;font-size:23px;color:#2A2420;line-height:1.1\">Estilo Moderno<\u002Fh3><p style=\"font-size:13.5px;line-height:1.55;color:#7a6f63;margin-top:5px;font-weight:300\">Cuello alto, sin mangas, silueta peplum.<\u002Fp><\u002Fdiv>\n          <span style=\"flex:none;width:16px;height:16px;border-radius:50%;margin-top:6px;border:1px solid rgba(0,0,0,.12);background:#4A3528\"><\u002Fspan>\n        <\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"lupa-card\" style=\"background:#FBF6EC;border:1px solid rgba(166,128,63,.2)\">\n        <div style=\"position:relative;overflow:hidden;aspect-ratio:3/4;background:#E7D8C4\"><img src=\"7aa1f1b9-7ae6-471e-a4b7-24265cfce633\" alt=\"Princesa\" class=\"lupa-img\" style=\"width:100%;height:100%;object-fit:cover;object-position:top\"><\u002Fdiv>\n        <div style=\"padding:18px 20px 22px;display:flex;align-items:flex-start;justify-content:space-between;gap:12px\">\n          <div><h3 style=\"font-family:'Cormorant Garamond',serif;font-weight:500;font-size:23px;color:#2A2420;line-height:1.1\">Princesa<\u002Fh3><p style=\"font-size:13.5px;line-height:1.55;color:#7a6f63;margin-top:5px;font-weight:300\">Escote en V con cuello y mangas globo.<\u002Fp><\u002Fdiv>\n          <span style=\"flex:none;width:16px;height:16px;border-radius:50%;margin-top:6px;border:1px solid rgba(0,0,0,.12);background:#2F4A38\"><\u002Fspan>\n        <\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"lupa-card\" style=\"background:#FBF6EC;border:1px solid rgba(166,128,63,.2)\">\n        <div style=\"position:relative;overflow:hidden;aspect-ratio:3/4;background:#E7D8C4\"><img src=\"ed8391bf-6410-43da-8e8e-88b51975ba92\" alt=\"Mangas con Volados\" class=\"lupa-img\" style=\"width:100%;height:100%;object-fit:cover;object-position:top\"><\u002Fdiv>\n        <div style=\"padding:18px 20px 22px;display:flex;align-items:flex-start;justify-content:space-between;gap:12px\">\n          <div><h3 style=\"font-family:'Cormorant Garamond',serif;font-weight:500;font-size:23px;color:#2A2420;line-height:1.1\">Mangas con Volados<\u002Fh3><p style=\"font-size:13.5px;line-height:1.55;color:#7a6f63;margin-top:5px;font-weight:300\">Volados al hombro y talle elastizado.<\u002Fp><\u002Fdiv>\n          <span style=\"flex:none;width:16px;height:16px;border-radius:50%;margin-top:6px;border:1px solid rgba(0,0,0,.12);background:#6B2230\"><\u002Fspan>\n        <\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"lupa-card\" style=\"background:#FBF6EC;border:1px solid rgba(166,128,63,.2)\">\n        <div style=\"position:relative;overflow:hidden;aspect-ratio:3/4;background:#E7D8C4\"><img src=\"bb19fe15-acbc-4a57-9aba-119056c03bf4\" alt=\"Mono\" class=\"lupa-img\" style=\"width:100%;height:100%;object-fit:cover;object-position:top\"><\u002Fdiv>\n        <div style=\"padding:18px 20px 22px;display:flex;align-items:flex-start;justify-content:space-between;gap:12px\">\n          <div><h3 style=\"font-family:'Cormorant Garamond',serif;font-weight:500;font-size:23px;color:#2A2420;line-height:1.1\">Mono<\u002Fh3><p style=\"font-size:13.5px;line-height:1.55;color:#7a6f63;margin-top:5px;font-weight:300\">Enterito utilitario con cordón en cintura.<\u002Fp><\u002Fdiv>\n          <span style=\"flex:none;width:16px;height:16px;border-radius:50%;margin-top:6px;border:1px solid rgba(0,0,0,.12);background:#5A2230\"><\u002Fspan>\n        <\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"lupa-card\" style=\"background:#FBF6EC;border:1px solid rgba(166,128,63,.2)\">\n        <div style=\"position:relative;overflow:hidden;aspect-ratio:3/4;background:#E7D8C4\"><img src=\"380509e9-6db0-4f90-9cfe-c68972224444\" alt=\"Rosa\" class=\"lupa-img\" style=\"width:100%;height:100%;object-fit:cover;object-position:top\"><\u002Fdiv>\n        <div style=\"padding:18px 20px 22px;display:flex;align-items:flex-start;justify-content:space-between;gap:12px\">\n          <div><h3 style=\"font-family:'Cormorant Garamond',serif;font-weight:500;font-size:23px;color:#2A2420;line-height:1.1\">Rosa<\u002Fh3><p style=\"font-size:13.5px;line-height:1.55;color:#7a6f63;margin-top:5px;font-weight:300\">Tono fucsia, bolsillos cargo, corte deportivo.<\u002Fp><\u002Fdiv>\n          <span style=\"flex:none;width:16px;height:16px;border-radius:50%;margin-top:6px;border:1px solid rgba(0,0,0,.12);background:#D6418A\"><\u002Fspan>\n        <\u002Fdiv>\n      <\u002Fdiv>\n\n    <\u002Fdiv>\n  <\u002Fsection>\n\n  <!-- EMPRESAS -->\n  <section id=\"empresas\" style=\"background:#EBDFCB;padding:clamp(72px,9vw,128px) clamp(20px,5vw,56px)\">\n    <div class=\"lupa-2col\" style=\"max-width:1180px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:clamp(36px,5vw,80px);align-items:center\">\n      <div style=\"position:relative;overflow:hidden;aspect-ratio:4/5;background:#cdb196;border:1px solid rgba(166,128,63,.3)\">\n        <img src=\"bd2ddfdf-88e1-4468-b3b2-190d476ea057\" alt=\"Equipo con ambos LUPA\" style=\"width:100%;height:100%;object-fit:cover;object-position:center 25%\">\n        <div style=\"position:absolute;inset:16px;border:1px solid rgba(244,236,223,.45);pointer-events:none\"><\u002Fdiv>\n      <\u002Fdiv>\n      <div>\n        <span style=\"font-size:12px;letter-spacing:.34em;text-transform:uppercase;color:#A6803F;font-weight:500\">Asesoría a empresas<\u002Fspan>\n        <h2 style=\"font-family:'Cormorant Garamond',serif;font-weight:400;font-size:clamp(32px,4.4vw,54px);line-height:1.08;letter-spacing:-.01em;margin:16px 0 0;color:#2A2420\">El ambo que identifica a tu equipo<\u002Fh2>\n        <p style=\"font-size:16.5px;line-height:1.78;color:#5C5249;font-weight:300;margin-top:22px\">Acompañamos a clínicas, consultorios y centros estéticos a definir su uniforme: color, corte y detalle que reflejen la identidad de la marca. Un equipo que viste igual de bien, transmite confianza.<\u002Fp>\n        <ul style=\"list-style:none;margin:26px 0 0;display:flex;flex-direction:column;gap:14px\">\n          <li style=\"display:flex;gap:12px;align-items:flex-start;font-size:15.5px;color:#3a342e;font-weight:300\"><span style=\"color:#A6803F;font-family:'Cormorant Garamond',serif;font-size:20px;line-height:1\">—<\u002Fspan> Selección de paleta acorde a tu marca<\u002Fli>\n          <li style=\"display:flex;gap:12px;align-items:flex-start;font-size:15.5px;color:#3a342e;font-weight:300\"><span style=\"color:#A6803F;font-family:'Cormorant Garamond',serif;font-size:20px;line-height:1\">—<\u002Fspan> Curva de talles para todo el equipo<\u002Fli>\n          <li style=\"display:flex;gap:12px;align-items:flex-start;font-size:15.5px;color:#3a342e;font-weight:300\"><span style=\"color:#A6803F;font-family:'Cormorant Garamond',serif;font-size:20px;line-height:1\">—<\u002Fspan> Posibilidad de bordado y personalización<\u002Fli>\n        <\u002Ful>\n        <a href=\"{{ waHref }}\" target=\"_blank\" rel=\"noopener\" class=\"lupa-btn\" style=\"text-decoration:none;display:inline-block;margin-top:32px;padding:15px 30px;background:#2A2420;color:#F4ECDF;border-radius:100px;font-size:12.5px;letter-spacing:.16em;text-transform:uppercase\" style-hover=\"background:#A6803F\">Solicitar asesoría<\u002Fa>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fsection>\n\n  <!-- CHOMBAS -->\n  <section style=\"padding:clamp(72px,9vw,128px) clamp(20px,5vw,56px);max-width:1180px;margin:0 auto\">\n    <div class=\"lupa-2col\" style=\"display:grid;grid-template-columns:1fr 1fr;gap:clamp(36px,5vw,80px);align-items:center\">\n      <div>\n        <span style=\"font-size:12px;letter-spacing:.34em;text-transform:uppercase;color:#A6803F;font-weight:500\">También<\u002Fspan>\n        <h2 style=\"font-family:'Cormorant Garamond',serif;font-weight:400;font-size:clamp(32px,4.4vw,54px);line-height:1.08;letter-spacing:-.01em;margin:16px 0 0;color:#2A2420\">Chombas empresariales<\u002Fh2>\n        <p style=\"font-size:16.5px;line-height:1.78;color:#5C5249;font-weight:300;margin-top:22px\">Sumamos chombas corporativas con la misma impronta LUPA: calce prolijo, telas nobles y la opción de bordar tu logo. Ideales para recepción, atención y eventos de tu empresa.<\u002Fp>\n        <a href=\"{{ waHref }}\" target=\"_blank\" rel=\"noopener\" class=\"lupa-btn\" style=\"text-decoration:none;display:inline-block;margin-top:30px;padding:15px 30px;border:1px solid #2A2420;color:#2A2420;border-radius:100px;font-size:12.5px;letter-spacing:.16em;text-transform:uppercase\" style-hover=\"background:#2A2420;color:#F4ECDF\">Consultar modelos<\u002Fa>\n      <\u002Fdiv>\n      <div style=\"position:relative;overflow:hidden;aspect-ratio:4/5;background:#E7D8C4;border:1px solid rgba(166,128,63,.35)\">\n        <img src=\"156aa935-5a30-476a-902c-9d08411a084d\" alt=\"Chombas empresariales LUPA\" class=\"lupa-img\" style=\"width:100%;height:100%;object-fit:cover;object-position:center 30%\">\n        <div style=\"position:absolute;inset:16px;border:1px solid rgba(244,236,223,.45);pointer-events:none\"><\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fsection>\n\n  <!-- FILOSOFIA / SOBRE -->\n  <section id=\"filosofia\" style=\"background:#9A6526;color:#FBF3E2;padding:clamp(72px,9vw,130px) clamp(20px,5vw,56px)\">\n    <div class=\"lupa-2col\" style=\"max-width:1180px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:clamp(36px,5vw,80px);align-items:center\">\n      <div>\n        <span style=\"font-size:12px;letter-spacing:.34em;text-transform:uppercase;color:#F3E7C6;font-weight:500\">Sobre LUPA<\u002Fspan>\n        <h2 style=\"font-family:'Cormorant Garamond',serif;font-weight:400;font-size:clamp(32px,4.4vw,54px);line-height:1.1;letter-spacing:-.01em;margin:16px 0 0;color:#F4ECDF\">Nuestra filosofía<\u002Fh2>\n        <p style=\"font-size:16.5px;line-height:1.8;color:rgba(251,243,226,.88);font-weight:300;margin-top:22px\">Creemos que la ropa de trabajo puede ser un acto de cuidado hacia una misma. Por eso unimos <em style=\"color:#FBEFD2;font-style:italic\">mente<\u002Fem> —diseño, función, calidad— y <em style=\"color:#FBEFD2;font-style:italic\">corazón<\u002Fem> —la emoción de sentirte hermosa mientras hacés lo que amás.<\u002Fp>\n        <p style=\"font-size:16.5px;line-height:1.8;color:rgba(251,243,226,.88);font-weight:300;margin-top:18px\">Así nace cada ambo LUPA: pensado para que ames ir a trabajar.<\u002Fp>\n      <\u002Fdiv>\n      <div style=\"position:relative;overflow:hidden;aspect-ratio:3/4;background:#4a3a2a;border:1px solid rgba(199,162,79,.4)\">\n        <img src=\"b11b45f1-14a3-463d-8dfd-b515165e6cfa\" alt=\"Detalle de diseño LUPA\" class=\"lupa-img\" style=\"width:100%;height:100%;object-fit:cover;object-position:top\">\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fsection>\n\n  <!-- TESTIMONIOS -->\n  <section style=\"padding:clamp(72px,9vw,128px) clamp(20px,5vw,56px);max-width:1180px;margin:0 auto\">\n    <div style=\"text-align:center;margin-bottom:clamp(34px,4vw,56px)\">\n      <span style=\"font-size:12px;letter-spacing:.34em;text-transform:uppercase;color:#A6803F;font-weight:500\">Lo que dicen<\u002Fspan>\n      <h2 style=\"font-family:'Cormorant Garamond',serif;font-weight:400;font-size:clamp(32px,4.4vw,54px);line-height:1.08;letter-spacing:-.01em;margin-top:14px;color:#2A2420\">Quienes ya visten LUPA<\u002Fh2>\n    <\u002Fdiv>\n    <div style=\"display:grid;grid-template-columns:repeat(auto-fit,minmax(min(300px,100%),1fr));gap:clamp(18px,2.4vw,30px)\">\n      <sc-for list=\"{{ testimonios }}\" as=\"t\" hint-placeholder-count=\"3\">\n      <div style=\"background:#FBF6EC;border:1px solid rgba(166,128,63,.2);padding:34px 30px;display:flex;flex-direction:column;gap:18px\">\n        <span style=\"font-family:'Cormorant Garamond',serif;font-size:50px;line-height:.6;color:#A6803F\">“<\u002Fspan>\n        <p style=\"font-size:16.5px;line-height:1.7;color:#3a342e;font-weight:300;font-style:italic\">{{ t.quote }}<\u002Fp>\n        <div style=\"margin-top:auto\">\n          <span style=\"display:block;font-family:'Cormorant Garamond',serif;font-size:18px;color:#2A2420\">{{ t.name }}<\u002Fspan>\n          <span style=\"display:block;font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:#A6803F;margin-top:3px\">{{ t.role }}<\u002Fspan>\n        <\u002Fdiv>\n      <\u002Fdiv>\n      <\u002Fsc-for>\n    <\u002Fdiv>\n  <\u002Fsection>\n\n  <!-- CONTACTO -->\n  <section id=\"contacto\" style=\"background:#EBDFCB;padding:clamp(72px,9vw,128px) clamp(20px,5vw,56px)\">\n    <div class=\"lupa-2col\" style=\"max-width:1080px;margin:0 auto;display:grid;grid-template-columns:1.1fr .9fr;gap:clamp(36px,5vw,72px);align-items:center\">\n      <div>\n        <span style=\"font-size:12px;letter-spacing:.34em;text-transform:uppercase;color:#A6803F;font-weight:500\">Contacto<\u002Fspan>\n        <h2 style=\"font-family:'Cormorant Garamond',serif;font-weight:400;font-size:clamp(36px,5vw,64px);line-height:1.04;letter-spacing:-.01em;margin:16px 0 0;color:#2A2420\">Hablemos de tu próximo ambo<\u002Fh2>\n        <p style=\"font-size:16.5px;line-height:1.78;color:#5C5249;font-weight:300;margin-top:22px;max-width:440px\">Escribinos por WhatsApp para conocer modelos, colores, talles y compras. Asesoramiento personalizado para profesionales y empresas.<\u002Fp>\n        <div style=\"margin-top:30px;display:flex;flex-direction:column;gap:6px\">\n          <span style=\"font-family:'Cormorant Garamond',serif;font-size:30px;color:#2A2420\">+54 9 3795 10-0554<\u002Fspan>\n          <span style=\"font-size:13px;letter-spacing:.18em;text-transform:uppercase;color:#A6803F\">Corrientes · Argentina<\u002Fspan>\n        <\u002Fdiv>\n      <\u002Fdiv>\n      <div style=\"background:#FBF6EC;border:1px solid rgba(166,128,63,.28);padding:clamp(28px,3vw,42px);display:flex;flex-direction:column;gap:16px\">\n        <h3 style=\"font-family:'Cormorant Garamond',serif;font-weight:500;font-size:24px;color:#2A2420\">Empezá hoy<\u002Fh3>\n        <a href=\"{{ waHref }}\" target=\"_blank\" rel=\"noopener\" class=\"lupa-btn\" style=\"text-decoration:none;text-align:center;padding:16px;background:#2A2420;color:#F4ECDF;border-radius:100px;font-size:12.5px;letter-spacing:.16em;text-transform:uppercase\" style-hover=\"background:#A6803F\">Escribir por WhatsApp<\u002Fa>\n        <a href=\"{{ tiendaHref }}\" target=\"_blank\" rel=\"noopener\" class=\"lupa-btn\" style=\"text-decoration:none;text-align:center;padding:16px;border:1px solid #2A2420;color:#2A2420;border-radius:100px;font-size:12.5px;letter-spacing:.16em;text-transform:uppercase\" style-hover=\"background:#2A2420;color:#F4ECDF\">Comprar online<\u002Fa>\n        <p style=\"font-size:13px;line-height:1.6;color:#7a6f63;font-weight:300;text-align:center;margin-top:4px\">Atención de lunes a sábado<\u002Fp>\n      <\u002Fdiv>\n    <\u002Fdiv>\n  <\u002Fsection>\n\n  <!-- FOOTER -->\n  <footer style=\"background:#2A2420;color:#F4ECDF;padding:clamp(48px,6vw,72px) clamp(20px,5vw,56px) 40px\">\n    <div style=\"max-width:1180px;margin:0 auto;display:flex;flex-wrap:wrap;gap:32px;align-items:center;justify-content:space-between\">\n      <div style=\"display:flex;align-items:center;gap:14px\">\n        <span style=\"display:grid;place-items:center;width:44px;height:44px;border:1.5px solid #C7A24F;border-radius:8px;font-family:'Cormorant Garamond',serif;font-weight:600;font-size:20px;color:#C7A24F;letter-spacing:1px\">LU<\u002Fspan>\n        <div style=\"display:flex;flex-direction:column;line-height:1\">\n          <span style=\"font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:600;letter-spacing:.14em\">LUPA<\u002Fspan>\n          <span style=\"font-size:9px;letter-spacing:.32em;text-transform:uppercase;color:#C7A24F;margin-top:4px\">ambos de diseño exclusivo<\u002Fspan>\n        <\u002Fdiv>\n      <\u002Fdiv>\n      <p style=\"font-family:'Cormorant Garamond',serif;font-style:italic;font-size:22px;color:rgba(244,236,223,.85)\">Pensados para que ames ir a trabajar.<\u002Fp>\n      <div style=\"display:flex;gap:26px;align-items:center\">\n        <a href=\"#coleccion\" style=\"text-decoration:none;color:rgba(244,236,223,.7);font-size:13px;letter-spacing:.12em;text-transform:uppercase\">Colección<\u002Fa>\n        <a href=\"#empresas\" style=\"text-decoration:none;color:rgba(244,236,223,.7);font-size:13px;letter-spacing:.12em;text-transform:uppercase\">Empresas<\u002Fa>\n        <a href=\"{{ waHref }}\" target=\"_blank\" rel=\"noopener\" style=\"text-decoration:none;color:#C7A24F;font-size:13px;letter-spacing:.12em;text-transform:uppercase\">WhatsApp<\u002Fa>\n      <\u002Fdiv>\n    <\u002Fdiv>\n    <div style=\"max-width:1180px;margin:36px auto 0;padding-top:24px;border-top:1px solid rgba(199,162,79,.22);display:flex;flex-wrap:wrap;gap:10px;justify-content:space-between;font-size:12px;color:rgba(244,236,223,.5);letter-spacing:.08em\">\n      <span>© 2026 LUPA · Corrientes, Argentina<\u002Fspan>\n      <span>+54 9 3795 10-0554<\u002Fspan>\n    <\u002Fdiv>\n  <\u002Ffooter>\n\n<\u002Fdiv>\n<\u002Fx-dc>\n<script type=\"text/x-dc\" data-dc-script=\"\" data-props=\"{&quot;heroVariant&quot;:{&quot;editor&quot;:&quot;enum&quot;,&quot;options&quot;:[&quot;A&quot;,&quot;B&quot;,&quot;C&quot;],&quot;default&quot;:&quot;A&quot;,&quot;tsType&quot;:&quot;string&quot;},&quot;whatsapp&quot;:{&quot;editor&quot;:&quot;text&quot;,&quot;default&quot;:&quot;5493795100554&quot;,&quot;tsType&quot;:&quot;string&quot;},&quot;tiendaHref&quot;:{&quot;editor&quot;:&quot;text&quot;,&quot;default&quot;:&quot;&quot;,&quot;tsType&quot;:&quot;string&quot;}}\">\nclass Component extends DCLogic {\n  renderVals() {\n    const v = this.props.heroVariant || 'A';\n    const wa = (this.props.whatsapp || '5493795100554').replace(/[^0-9]/g, '');\n    return {\n      heroA: v === 'A',\n      heroB: v === 'B',\n      heroC: v === 'C',\n      waHref: 'https://wa.me/' + wa,\n      tiendaHref: this.props.tiendaHref || 'https://wa.me/' + wa,\n      modelos: [\n        { name: 'Bordó',             img: 'img/bordo.jpg',          desc: 'Escote con cierre dorado y peplum entallado.', color: '#6B2230' },\n        { name: 'Nude',              img: 'img/claro.jpg',          desc: 'Mangas plisadas y caída fluida.',              color: '#D9A98E' },\n        { name: 'Estilo Moderno',    img: 'img/estilo-moderno.jpg', desc: 'Cuello alto, sin mangas, silueta peplum.',     color: '#4A3528' },\n        { name: 'Princesa',          img: 'img/verde.jpg',          desc: 'Escote en V con cuello y mangas globo.',       color: '#2F4A38' },\n        { name: 'Mangas con Volados',img: 'img/volados.jpg',        desc: 'Volados al hombro y talle elastizado.',        color: '#6B2230' },\n        { name: 'Mono',              img: 'img/mono.jpg',           desc: 'Enterito utilitario con cordón en cintura.',   color: '#5A2230' },\n        { name: 'Rosa',              img: 'img/rosa.jpg',           desc: 'Tono fucsia, bolsillos cargo, corte deportivo.', color: '#D6418A' }\n      ],\n      testimonios: [\n        { quote: 'Desde que uso LUPA, entrar al consultorio se siente distinto. Me siento yo, prolija y cómoda todo el día.', name: 'Carla', role: 'Odontóloga' },\n        { quote: 'Vestimos a todo el equipo con la misma línea. La imagen de la clínica cambió por completo.', name: 'Mariana', role: 'Centro estético' },\n        { quote: 'Cortes que entallan de verdad. Por fin un ambo que se ve elegante y no parece uniforme.', name: 'Luciana', role: 'Kinesióloga' }\n      ]\n    };\n  }\n}\n<\u002Fscript>\n\n\n<\u002Fbody><\u002Fhtml>"
  </script>
</body>
</html>
